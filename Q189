// Rotate Array

class Solution {
    public void rotate(int[] nums, int k) {

        if(nums.length==1)
            return;

        int n= nums.length-1;
        k= k%(n+1);
        looping(nums, 0, n);
        looping(nums, 0, k-1);
        looping(nums, k, n);
    }
    public void looping(int[] arr, int i, int j)
    {
        while(i<j)
        {
            int temp= arr[i];
            arr[i]= arr[j];
            arr[j]= temp;
            i++;
            j--;
        }
    }
}
